{
  "name": "cursor-base",
  "private": true,
  "description": "Canonical shared Cursor toolkit repository (workspace root)",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build -w cursor-kit",
    "test": "npm run test -w cursor-kit",
    "typecheck": "npm run typecheck -w cursor-kit",
    "lint": "npm run lint -w cursor-kit",
    "cursor-kit": "npm run start -w cursor-kit --"
  }
}
