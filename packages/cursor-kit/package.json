{
  "name": "cursor-kit",
  "version": "0.2.0",
  "description": "CLI to copy the shared Cursor toolkit from cursor-base into your project repository",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cursor-sh/cursor-base.git",
    "directory": "packages/cursor-kit"
  },
  "bugs": {
    "url": "https://github.com/cursor-sh/cursor-base/issues"
  },
  "homepage": "https://github.com/cursor-sh/cursor-base/tree/main/packages/cursor-kit#readme",
  "keywords": [
    "cursor",
    "cursor-editor",
    "cli",
    "toolkit",
    "dotcursor"
  ],
  "bin": {
    "cursor-kit": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "start": "node ./dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "prepack": "npm run build"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.1",
    "eslint": "^9.15.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
